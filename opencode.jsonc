{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{{KEY}}"
      },
      "enabled": true
    },
    "semgrep": {
      "type": "local",
      "command": ["semgrep", "mcp"],
      "enabled": true
    }
  },
  "default_agent": "plan",
  "agent": {
    "plan": {
      "description": "Read-only Principal Architect. Investigates the codebase and writes the implementation plan to PLAN.md. Cannot edit source.",
      "model": "deepseek/deepseek-v4-pro",
      "reasoningEffort": "xhigh",
      "prompt": "{file:./architect.md}",
      "temperature": 1.0,
      "permission": {
        "edit": { "*": "deny", "PLAN.md": "allow" },
        "websearch": "allow",
        "bash": {
          "*": "deny",
          "git status*": "allow",
          "git diff HEAD*": "allow",
          "git log*": "allow"
        }
      }
    },
    "build": {
      "description": "Executing Builder. Implements PLAN.md to the letter, runs tests, leaves changes uncommitted for review.",
      "model": "deepseek/deepseek-v4-pro",
      "reasoningEffort": "high",
      "prompt": "{file:./build.md}",
      "temperature": 1.0,
      "permission": {
        "bash": {
          "git push --force*": "deny",
          "git push -f*": "deny",
          "git reset*": "deny",
          "git rebase*": "deny",
          "git rm*": "deny",
          "git checkout*": "deny",
          "git clean*": "deny",
          "git stash*": "deny",
          "git merge*": "deny",
          "git branch -D*": "deny",
          "git pull*": "deny"
        }
      }
    },
    "1-review-plan": {
      "description": "Step 1: @1-review-plan — reviews the PLAN for judgment flaws BEFORE any code is written.",
      "mode": "subagent",
      "model": "opencode-go/kimi-k2.6",
      "temperature": 1.0,
      "prompt": "{file:./1-review-plan.md}",
      "permission": {
        "edit": "deny",
        "websearch": "allow",
        "bash": {
          "*": "deny",
          "git status*": "allow",
          "git diff HEAD*": "allow",
          "git log*": "allow"
        }
      }
    },
    "2-check-drift": {
      "description": "Step 2: @2-check-drift — checks whether the implementation matches PLAN.md AFTER a build (omissions, deviations, out-of-scope). Does not judge plan quality.",
      "mode": "subagent",
      "model": "opencode-go/glm-5.1",
      "temperature": 0.6,
      "prompt": "{file:./2-check-drift.md}",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git status*": "allow",
          "git diff HEAD*": "allow",
          "git log*": "allow"
        }
      }
    },
    "3-review-code": {
      "description": "Step 3: @3-review-code — reviews CODE QUALITY (bugs, security via Semgrep, anti-patterns) AFTER drift-check. Does not check conformance (that's 2-check-drift's job).",
      "mode": "subagent",
      "model": "opencode-go/kimi-k2.6",
      "temperature": 1.0,
      "prompt": "{file:./3-review-code.md}",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git status*": "allow",
          "git diff HEAD*": "allow",
          "git log*": "allow"
        }
      }
    }
  }
}